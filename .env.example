# code-brain Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# AI Chat Providers
# ============================================

# Anthropic (Claude) - Best for code reasoning
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT-4, GPT-3.5) - Fast and reliable
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Ollama - Local AI (no key needed, just install Ollama)
# Download from: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# Embedding Providers (for semantic search)
# ============================================

# Voyage AI (Anthropic's embedding partner) - Best for code
# Get your key from: https://www.voyageai.com/
VOYAGE_API_KEY=pa-your-key-here

# OpenAI Embeddings (alternative)
# Uses the same OPENAI_API_KEY as above

# ============================================
# HTTP Server Security
# ============================================

# API key for HTTP server (optional, for team/CI environments)
CODE_BRAIN_API_KEY=your-secret-key-here

# ============================================
# Default Chat Settings
# ============================================

# Default AI provider: anthropic, openai, or ollama
CODE_BRAIN_CHAT_PROVIDER=anthropic

# Default model for each provider
CODE_BRAIN_ANTHROPIC_MODEL=claude-sonnet-4-20250514
CODE_BRAIN_OPENAI_MODEL=gpt-4-turbo-preview
CODE_BRAIN_OLLAMA_MODEL=llama3

# ============================================
# Notes
# ============================================

# 1. Copy this file to .env in your project root
# 2. Fill in the API keys you want to use
# 3. The .env file is automatically loaded by code-brain
# 4. You can also use .codebrainrc.json for configuration
# 5. Environment variables take precedence over .codebrainrc.json
