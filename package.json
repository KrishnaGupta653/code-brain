{
  "name": "code-brain",
  "version": "1.0.0",
  "description": "Deterministic codebase intelligence system. Builds persistent knowledge graphs with structured provenance.",
  "main": "dist/index.js",
  "bin": {
    "code-brain": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "clean": "rimraf dist .codebrain",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "codebase",
    "knowledge-graph",
    "provenance",
    "analysis",
    "ai-context"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "lodash": "^4.17.21",
    "ora": "^8.0.1",
    "typescript": "^5.3.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}