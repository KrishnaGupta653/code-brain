{
  "name": "code-brain",
  "version": "1.0.0",
  "description": "Multi-language codebase intelligence system with AST-based parsing, knowledge graphs, and AI-optimized exports. Supports TypeScript, JavaScript, Java, Python, Go, Rust, C#, C, C++, Ruby, PHP, Kotlin, Scala, Elixir, and Haskell with fallback coverage for many more languages.",
  "main": "dist/index.js",
  "bin": {
    "code-brain": "dist/cli/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run typecheck:ui && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "vite build --config ui/vite.config.ts",
    "typecheck:ui": "tsc -p ui/tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:ui-smoke": "node tests/ui-smoke.mjs",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "clean": "rimraf dist ui/dist",
    "clean:data": "rimraf .codebrain",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "codebase",
    "knowledge-graph",
    "ast",
    "tree-sitter",
    "code-analysis",
    "static-analysis",
    "provenance",
    "ai-context",
    "mcp",
    "typescript",
    "javascript",
    "java",
    "python",
    "go",
    "rust",
    "csharp",
    "c",
    "cpp",
    "ruby",
    "php",
    "kotlin",
    "scala",
    "elixir",
    "haskell",
    "graph-database",
    "code-intelligence"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-sigma/core": "^5.0.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphql": "^16.13.2",
    "lodash": "^4.17.21",
    "lucide-react": "^1.11.0",
    "ora": "^8.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sigma": "^3.0.2",
    "simple-git": "^3.36.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c": "^0.21.4",
    "tree-sitter-c-sharp": "^0.21.3",
    "tree-sitter-cpp": "^0.21.0",
    "tree-sitter-elixir": "^0.3.5",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-haskell": "^0.23.1",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.22.8",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-ruby": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-typescript": "^0.21.0",
    "typescript": "^5.3.3",
    "ws": "^8.20.0",
    "yaml": "^2.8.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "playwright": "^1.59.1",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
